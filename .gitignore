# pyenv
#   For a library or binary, you should probably not check in .python-version
# .python-version

# pipenv
#   According to pypa/pipenv#1185, it is recommended to check in Pipfile.lock.
#   However, in case of a library, see pypa/pipenv#1185.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, it is generally recommended to check in poetry.lock.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, it is generally recommended to check in pdm.lock.
#pdm.lock

# PEP 582; used by e.g. pdm.
__pypackages__/

